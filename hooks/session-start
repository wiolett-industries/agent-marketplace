#!/usr/bin/env bash
# SessionStart hook for project-memory plugin
# Injects light-layer entries + deep memory topic index into every session.

set -euo pipefail

DB_PATH="${PWD}/.memory/memory.db"

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

emit() {
    local context_escaped
    context_escaped=$(escape_for_json "$1")
    cat <<EOF
{
  "additional_context": "${context_escaped}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${context_escaped}"
  }
}
EOF
}

if [ ! -f "$DB_PATH" ]; then
    emit "<project-memory>No memory database found for this project. Run /project-memory:memory-setup to enable project memory.</project-memory>"
    exit 0
fi

MEMORY_OUTPUT=$(DB_PATH="$DB_PATH" node --no-warnings --input-type=module <<'NODEJS'
import { DatabaseSync } from 'node:sqlite';

const db = new DatabaseSync(process.env.DB_PATH);

// Light entries (pointers + critical facts)
const lightRows = db.prepare(
  "SELECT content, tags FROM entries WHERE layer = 'light' ORDER BY updated_at DESC"
).all();

// Topic index from deep entry tags
const deepRows = db.prepare(
  "SELECT tags FROM entries WHERE layer = 'deep'"
).all();

const topicSet = new Set();
for (const row of deepRows) {
  const tags = JSON.parse(row.tags);
  for (const tag of tags) topicSet.add(tag);
}

const lightSection = lightRows.length === 0
  ? '(none yet)'
  : lightRows.map(r => {
      const tags = JSON.parse(r.tags);
      const tagStr = tags.length > 0 ? ` [${tags.join(', ')}]` : '';
      return `- ${r.content}${tagStr}`;
    }).join('\n');

const topicSection = topicSet.size === 0
  ? '(none yet — save entries with tags to build the index)'
  : Array.from(topicSet).sort().join(', ');

console.log(`<project-memory>
## Always-loaded context (light layer)
${lightSection}

## Deep memory topics — call memory_search(topic) to load details
${topicSection}
</project-memory>`);
NODEJS
)

emit "$MEMORY_OUTPUT"
exit 0
