#!/usr/bin/env bash
# UserPromptSubmit hook for project-memory.
# Injects lite memory + deep topic index once per agent session.

set -euo pipefail

DB_PATH="${PWD}/.memory/memory.db"
SESSION_KEY="${CODEX_SESSION_ID:-${CLAUDE_SESSION_ID:-}}"
if [ -z "$SESSION_KEY" ]; then
    SESSION_KEY="$(ps -o sess= -p $$ 2>/dev/null | tr -d ' ' || true)"
fi
if [ -z "$SESSION_KEY" ]; then
    SESSION_KEY="$(ps -o sid= -p $$ 2>/dev/null | tr -d ' ' || true)"
fi
SESSION_KEY="${SESSION_KEY:-$$}"
FLAG_FILE="/tmp/.project-memory-injected-${SESSION_KEY}"

if [ -f "$FLAG_FILE" ]; then
    echo '{}'
    exit 0
fi

if [ ! -f "$DB_PATH" ]; then
    echo '{}'
    exit 0
fi

touch "$FLAG_FILE"

emit_message() {
    local msg="$1"
    msg="${msg//\\/\\\\}"
    msg="${msg//\"/\\\"}"
    msg="${msg//$'\n'/\\n}"
    msg="${msg//$'\r'/\\r}"
    msg="${msg//$'\t'/\\t}"
    printf '{"systemMessage":"%s"}\n' "$msg"
}

MEMORY_OUTPUT=$(DB_PATH="$DB_PATH" node --no-warnings --input-type=module <<'NODEJS'
import { DatabaseSync } from 'node:sqlite';

const db = new DatabaseSync(process.env.DB_PATH);

const cols = db.prepare("PRAGMA table_info(entries)").all();
if (!cols.some(c => c.name === 'ref')) {
  db.prepare("ALTER TABLE entries ADD COLUMN ref TEXT DEFAULT NULL").run();
}
if (!cols.some(c => c.name === 'hash')) {
  db.prepare("ALTER TABLE entries ADD COLUMN hash TEXT DEFAULT NULL").run();
}
db.prepare("UPDATE entries SET layer = 'lite' WHERE layer = 'light'").run();

const liteRows = db.prepare(
  "SELECT id, content, tags, ref FROM entries WHERE layer = 'lite' ORDER BY updated_at DESC"
).all();

const deepRows = db.prepare(
  "SELECT tags FROM entries WHERE layer = 'deep'"
).all();

const topicSet = new Set();
for (const row of deepRows) {
  for (const tag of JSON.parse(row.tags)) topicSet.add(tag);
}

const liteSection = liteRows.length === 0
  ? '(none yet)'
  : liteRows.map(r => {
      const tags = JSON.parse(r.tags);
      const tagStr = tags.length > 0 ? ` [${tags.join(', ')}]` : '';
      return `- ${r.content}${tagStr}`;
    }).join('\n');

const topicSection = topicSet.size === 0
  ? '(none yet)'
  : Array.from(topicSet).sort().join(', ');

process.stdout.write(`<project-memory>\nIMPORTANT: You MUST load the skill project-memory:using-project-memory using the Skill tool NOW before responding. This is not optional — the skill contains critical instructions for how to use project memory correctly.\n\n## Lite memory (always loaded)\n${liteSection}\n\n## Deep memory topics — use memory_get(id) or memory_search(topic)\n${topicSection}\n</project-memory>`);
NODEJS
)

emit_message "$MEMORY_OUTPUT"
exit 0
